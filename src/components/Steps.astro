---
/**
 * Infographie « Comment ça marche » — 3 à 4 étapes avec pictos SVG minimalistes.
 * Vectoriel et inline : zéro requête, parfait pour la perf (Core Web Vitals).
 */
interface Step {
  title: string;
  body: string;
  icon: 'building' | 'percent' | 'calendar' | 'piggy';
}
interface Props {
  steps: Step[];
  title?: string;
}
const { steps, title } = Astro.props;

const icons: Record<Step['icon'], string> = {
  building:
    '<path d="M9 21V5a1 1 0 0 1 1-1h7a1 1 0 0 1 1 1v16M5 21V11a1 1 0 0 1 1-1h3M3 21h18M12 8h2M12 12h2M12 16h2"/>',
  percent:
    '<path d="M19 5 5 19M6.5 9a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM17.5 20a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"/>',
  calendar:
    '<path d="M3 9h18M7 3v3m10-3v3M5 5h14a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z"/>',
  piggy:
    '<path d="M19 10c1 0 2 1 2 3s-1 3-2 3v2h-3v-1.5A6 6 0 0 1 5 13c0-3.3 2.7-6 6-6h3a4 4 0 0 1 4 3ZM7 13h.01M15 7l-1-3"/>',
};
---

<section class="steps-block">
  {title && <h2 class="steps-heading">{title}</h2>}
  <ol class="steps-grid">
    {
      steps.map((step, i) => (
        <li class="step">
          <span class="step-num">{i + 1}</span>
          <span class="step-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={icons[step.icon]} />
          </span>
          <h3 class="step-title">{step.title}</h3>
          <p class="step-body">{step.body}</p>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .steps-heading {
    text-align: center;
    margin-bottom: var(--space-8);
  }
  .steps-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-6);
  }
  @media (min-width: 720px) {
    .steps-grid {
      grid-template-columns: repeat(var(--cols, 4), 1fr);
    }
  }
  .step {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--space-8) var(--space-6) var(--space-6);
    box-shadow: var(--shadow-sm);
    margin: 0;
  }
  .step-num {
    position: absolute;
    top: -14px;
    left: var(--space-6);
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: var(--primary);
    color: #fff;
    font-weight: 800;
    font-size: 0.9rem;
    display: grid;
    place-items: center;
  }
  .step-icon {
    display: inline-grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--accent-soft);
    color: var(--accent);
    margin-bottom: var(--space-3);
  }
  .step-title {
    font-size: 1.05rem;
    margin: 0 0 var(--space-2);
  }
  .step-body {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
</style>
