---
/**
 * Encart éditorial (« à retenir », avertissement…).
 * Style « filet + intertitre » de presse, sans emoji ni marqueur générique.
 */
interface Props {
  title?: string;
  /** Teinte : info (encre) ou warning (laiton/ambre). */
  tone?: 'info' | 'warning';
}
const { title = 'À retenir', tone = 'info' } = Astro.props;
---

<aside class={`callout callout-${tone}`}>
  <p class="callout-kicker">{title}</p>
  <div class="callout-body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    padding: var(--space-5) var(--space-6) var(--space-4);
    margin: var(--space-8) 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--primary);
  }
  .callout-warning {
    border-left-color: var(--accent);
    background: var(--warning-soft);
  }
  .callout-kicker {
    margin: 0 0 var(--space-2);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--primary);
  }
  .callout-warning .callout-kicker {
    color: var(--accent);
  }
  .callout-body :global(ul) {
    margin: 0;
  }
  .callout-body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
