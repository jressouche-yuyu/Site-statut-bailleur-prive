---
/**
 * Couverture d'article / carte.
 * - Si `src` est fourni (photo réelle : chemin local sous /public ou URL),
 *   on affiche la photo (avec crédit optionnel).
 * - Sinon, on génère une couverture SVG brandée et déterministe (skyline
 *   immobilière), unique par `seed` mais cohérente avec l'identité du site.
 *   → Aucune image manquante, et on remplace par une vraie photo quand on veut.
 */
import { url } from '../lib/url';

interface Props {
  /** Photo réelle (optionnelle). Chemin sous /public (ex. /images/blog/x.jpg) ou URL absolue. */
  src?: string;
  alt?: string;
  /** Crédit photo — accepté pour compat, non affiché (crédits masqués). */
  credit?: string;
  /** Graine déterministe pour la couverture générée (slug, titre…). */
  seed?: string;
  /** Format : 'banner' (3:1, en-tête) ou 'thumb' (16:9, vignette). */
  variant?: 'banner' | 'thumb';
  /** Pictogramme SVG central (chemin path d) optionnel. */
  icon?: 'building' | 'key' | 'doc' | 'chart';
  class?: string;
  /** Chargement image. */
  loading?: 'lazy' | 'eager';
}
const { src, alt = '', seed = 'bp', variant = 'thumb', icon, class: className, loading = 'lazy' } = Astro.props;

// Hash déterministe.
let h = 0;
for (const c of seed) h = (h * 31 + c.charCodeAt(0)) >>> 0;
function rng(s: number) {
  return () => {
    s |= 0;
    s = (s + 0x6d2b79f5) | 0;
    let t = Math.imul(s ^ (s >>> 15), 1 | s);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rand = rng(h);
const gid = `cv${h.toString(36)}`;

// Skyline : barres d'immeubles de hauteurs variées.
const count = 13;
const buildings = Array.from({ length: count }, (_, i) => {
  const bh = 90 + Math.round(rand() * 200);
  return { x: i * 95 + 8, w: 70 + Math.round(rand() * 16), h: bh };
});

const iconPaths: Record<NonNullable<Props['icon']>, string> = {
  building: 'M9 21V5a1 1 0 0 1 1-1h7a1 1 0 0 1 1 1v16M5 21V11a1 1 0 0 1 1-1h3M3 21h18M12 8h2M12 12h2M12 16h2',
  key: 'M14 7a4 4 0 1 1-4 4M14 7l6-4M18 5l2 2-2 2M10 11l-7 7v3h3l1-1h2v-2h2l1-1',
  doc: 'M7 3h7l5 5v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1ZM14 3v5h5M9 13h6M9 17h6',
  chart: 'M4 20V10M10 20V4M16 20v-7M22 20H2',
};
---

{
  src ? (
    <figure class:list={['cover', `cover-${variant}`, className]}>
      <img src={src.startsWith('http') ? src : url(src)} alt={alt} loading={loading} decoding="async" />
    </figure>
  ) : (
    <div class:list={['cover', `cover-${variant}`, className]} role="img" aria-label={alt || undefined} aria-hidden={alt ? undefined : 'true'}>
      <svg viewBox="0 0 1200 400" preserveAspectRatio="xMidYMid slice" role="presentation">
        <defs>
          <linearGradient id={`${gid}g`} x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="#1d2a3f" />
            <stop offset="1" stop-color="#3a4a63" />
          </linearGradient>
          <linearGradient id={`${gid}v`} x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#0e1526" stop-opacity="0" />
            <stop offset="1" stop-color="#0e1526" stop-opacity="0.5" />
          </linearGradient>
        </defs>
        <rect width="1200" height="400" fill={`url(#${gid}g)`} />
        {/* skyline */}
        {buildings.map((b) => (
          <g fill="rgba(255,255,255,0.12)">
            <rect x={b.x} y={400 - b.h} width={b.w} height={b.h} rx="4" />
            {Array.from({ length: Math.floor(b.h / 34) }).map((_, r) => (
              <g fill="rgba(255,255,255,0.18)">
                <rect x={b.x + 10} y={400 - b.h + 14 + r * 34} width="14" height="14" rx="2" />
                <rect x={b.x + 34} y={400 - b.h + 14 + r * 34} width="14" height="14" rx="2" />
              </g>
            ))}
          </g>
        ))}
        {/* courbe d'amortissement */}
        <polyline points="40,330 220,300 400,300 560,250 760,210 980,150 1160,90" fill="none" stroke="#d8a24a" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" opacity="0.9" />
        <rect width="1200" height="400" fill={`url(#${gid}v)`} />
        {icon && (
          <g transform="translate(600 175) scale(5)" fill="none" stroke="rgba(255,255,255,0.92)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <path transform="translate(-12 -12)" d={iconPaths[icon]} />
          </g>
        )}
      </svg>
    </div>
  )
}

<style>
  .cover {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--surface-2);
    margin: 0;
  }
  .cover-banner {
    aspect-ratio: 3 / 1;
  }
  .cover-thumb {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius) var(--radius) 0 0;
  }
  .cover svg,
  .cover img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .cover-credit {
    position: absolute;
    right: 6px;
    bottom: 6px;
    font-size: 0.68rem;
    color: #fff;
    background: rgba(11, 28, 51, 0.55);
    padding: 1px 7px;
    border-radius: 999px;
  }
</style>
