---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Callout from '../components/Callout.astro';
import { loyerTiers, dispositif } from '../data/dispositif';
import { breadcrumbSchema, howToSchema } from '../lib/schema';
import { url } from '../lib/url';

const crumbs = [
  { name: 'Accueil', path: '/' },
  { name: "Simulateur d'amortissement", path: '/simulateur' },
];

// Données transmises au script client.
const tiersData = loyerTiers.map((t) => ({
  key: t.key,
  label: t.label,
  rateNeuf: t.rateNeuf,
  rateAncien: t.rateAncien,
  cap: t.deductionCap,
}));
const config = {
  share: dispositif.amortizableShare,
  years: dispositif.engagementYears,
};

// Cas concrets pré-remplis (réalistes, à titre d'exemple).
const presets = [
  {
    id: 'studio-neuf',
    label: 'Studio neuf · loyer intermédiaire',
    sub: '≈ 165 000 € · Nantes',
    values: { price: 165000, segment: 'neuf', tier: 'intermediaire', rent: 520, charges: 1500, interests: 3400, tmi: '0.30' },
  },
  {
    id: 't2-neuf-social',
    label: 'T2 neuf · loyer social',
    sub: '≈ 230 000 € · Lyon',
    values: { price: 230000, segment: 'neuf', tier: 'social', rent: 690, charges: 2200, interests: 5200, tmi: '0.41' },
  },
  {
    id: 't3-ancien',
    label: 'T3 ancien rénové · loyer intermédiaire',
    sub: '≈ 250 000 € · Lille',
    values: { price: 250000, segment: 'ancien', tier: 'intermediaire', rent: 880, charges: 2600, interests: 5600, tmi: '0.30' },
  },
];

const jsonLd = [
  breadcrumbSchema(crumbs),
  howToSchema({
    name: "Simuler l'amortissement et l'économie d'impôt du dispositif Jeanbrun",
    description: "Estimer l'amortissement, le revenu foncier imposable et l'économie d'impôt du statut du bailleur privé selon un projet réel.",
    steps: [
      { title: "Décrire le bien et le loyer", body: 'Prix, neuf ou ancien, catégorie de loyer et loyer mensuel perçu.' },
      { title: 'Ajouter charges et intérêts', body: 'Charges déductibles annuelles et intérêts d\'emprunt pour un calcul réaliste.' },
      { title: 'Renseigner votre tranche d\'imposition', body: 'Pour comparer l\'impôt avec et sans le dispositif et l\'économie sur 9 ans.' },
    ],
  }),
];
---

<BaseLayout
  title="Simulateur dispositif Jeanbrun : amortissement & économie d'impôt"
  description="Simulateur avancé du statut du bailleur privé : amortissement, revenu foncier imposable, comparaison avec/sans dispositif et économie d'impôt sur 9 ans, à partir d'un cas réel (loyer, charges, intérêts, TMI)."
  path="/simulateur"
  jsonLd={jsonLd}
>
  <div class="container container-narrow">
    <Breadcrumbs items={crumbs} />
    <p class="eyebrow">Outil gratuit · calcul instantané</p>
    <h1>Simulateur du statut du bailleur privé</h1>
    <p class="lead">
      Un simulateur complet et concret : il compare votre impôt foncier
      <strong> avec et sans</strong> le dispositif Jeanbrun, année par année, et
      estime votre <strong>économie d'impôt sur 9 ans</strong> ainsi que votre
      effort d'épargne mensuel.
    </p>

    <div class="presets">
      <span class="presets-label">Charger un cas concret :</span>
      <div class="presets-row">
        {
          presets.map((p) => (
            <button type="button" class="preset" data-preset={p.id}>
              <span class="preset-label">{p.label}</span>
              <span class="preset-sub">{p.sub}</span>
            </button>
          ))
        }
      </div>
    </div>

    <form id="sim-form" class="sim card" novalidate>
      <div class="field">
        <label for="price">Prix d'acquisition (€)</label>
        <input type="number" id="price" name="price" min="0" step="1000" value="230000" inputmode="numeric" />
      </div>

      <div class="field">
        <span class="field-label">Type de bien</span>
        <div class="radio-row" role="radiogroup" aria-label="Type de bien">
          <label class="radio"><input type="radio" name="segment" value="neuf" checked /> Neuf</label>
          <label class="radio"><input type="radio" name="segment" value="ancien" /> Ancien rénové</label>
        </div>
      </div>

      <div class="field">
        <label for="tier">Catégorie de loyer</label>
        <select id="tier" name="tier">
          {loyerTiers.map((t) => <option value={t.key}>{t.label}</option>)}
        </select>
      </div>

      <div class="field">
        <label for="rent">Loyer mensuel perçu (€, hors charges)</label>
        <input type="number" id="rent" name="rent" min="0" step="10" value="690" inputmode="numeric" />
      </div>

      <div class="field">
        <label for="charges">Charges annuelles déductibles (€)</label>
        <input type="number" id="charges" name="charges" min="0" step="100" value="2200" inputmode="numeric" />
        <p class="hint">Taxe foncière, assurance, gestion, copropriété non récupérable…</p>
      </div>

      <div class="field">
        <label for="interests">Intérêts d'emprunt annuels (€)</label>
        <input type="number" id="interests" name="interests" min="0" step="100" value="5200" inputmode="numeric" />
        <p class="hint">Moyenne annuelle des intérêts (hors capital).</p>
      </div>

      <div class="field">
        <label for="tmi">Tranche marginale d'imposition (TMI)</label>
        <select id="tmi" name="tmi">
          <option value="0">0 %</option>
          <option value="0.11">11 %</option>
          <option value="0.30" selected>30 %</option>
          <option value="0.41">41 %</option>
          <option value="0.45">45 %</option>
        </select>
        <p class="hint">+ 17,2 % de prélèvements sociaux appliqués au revenu foncier.</p>
      </div>

      <div class="field">
        <label for="mensualite">Mensualité de crédit (€, optionnel)</label>
        <input type="number" id="mensualite" name="mensualite" min="0" step="10" value="0" inputmode="numeric" />
        <p class="hint">Pour estimer l'effort d'épargne mensuel. Laissez 0 si non concerné.</p>
      </div>
    </form>

    <!-- Synthèse chiffrée -->
    <section class="results" id="results" aria-live="polite">
      <div class="result-cards">
        <div class="result-card">
          <p class="result-label">Amortissement déductible / an</p>
          <p class="result-value" id="r-annual">—</p>
          <p class="result-foot" id="r-rate">—</p>
        </div>
        <div class="result-card accent">
          <p class="result-label">Économie d'impôt / an</p>
          <p class="result-value" id="r-save">—</p>
          <p class="result-foot" id="r-save-foot">avec le dispositif Jeanbrun</p>
        </div>
        <div class="result-card accent">
          <p class="result-label">Économie sur 9 ans</p>
          <p class="result-value" id="r-save9">—</p>
          <p class="result-foot">durée d'engagement</p>
        </div>
        <div class="result-card">
          <p class="result-label">Effort d'épargne / mois</p>
          <p class="result-value" id="r-effort">—</p>
          <p class="result-foot" id="r-effort-foot">crédit + charges − loyer − éco. d'impôt</p>
        </div>
      </div>

      <!-- Graphique comparatif -->
      <div class="chart card">
        <h2 class="chart-title">Impôt foncier annuel : avec vs sans dispositif</h2>
        <div id="chart" class="chart-area"></div>
        <p class="chart-note" id="chart-note"></p>
      </div>

      <!-- Détail du calcul -->
      <div class="card detail">
        <h2 class="detail-title">Le détail du calcul (par an)</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>Poste</th><th>Sans dispositif</th><th>Avec Jeanbrun</th></tr>
            </thead>
            <tbody>
              <tr><td>Loyers perçus</td><td id="d-rent-1">—</td><td id="d-rent-2">—</td></tr>
              <tr><td>− Charges déductibles</td><td id="d-charges-1">—</td><td id="d-charges-2">—</td></tr>
              <tr><td>− Intérêts d'emprunt</td><td id="d-int-1">—</td><td id="d-int-2">—</td></tr>
              <tr><td>− Amortissement</td><td id="d-amort-1">—</td><td id="d-amort-2">—</td></tr>
              <tr class="row-strong"><td>= Revenu foncier imposable</td><td id="d-base-1">—</td><td id="d-base-2">—</td></tr>
              <tr><td>Impôt + prélèvements sociaux</td><td id="d-tax-1">—</td><td id="d-tax-2">—</td></tr>
            </tbody>
          </table>
        </div>
        <p class="detail-narrative" id="narrative"></p>
      </div>
    </section>

    <Callout title="Comment lire ce résultat ?">
      <p>
        Le dispositif permet de déduire l'amortissement de vos revenus fonciers,
        ce qui réduit votre base imposable. L'économie réelle dépend de votre TMI
        et des prélèvements sociaux (17,2 %). Si l'amortissement dépasse le revenu
        foncier imposable, l'excédent n'est pas perdu : il est <strong>reporté</strong>
        sur les années suivantes (pris en compte dans l'estimation annuelle).
      </p>
    </Callout>

    <Callout title="Estimation indicative — pas un conseil fiscal" tone="warning">
      <p>
        Calcul simplifié : il ne tient pas compte de toute votre situation (autres
        revenus fonciers, déficit imputable sur le revenu global, plus-value à la
        revente, plafonds spécifiques). Les taux et plafonds reflètent la version
        adoptée fin 2025 et peuvent évoluer. Pour la méthode, voir
        <a href={url('/guides/comment-fonctionne-statut-bailleur-prive')}> notre guide</a>.
      </p>
    </Callout>
  </div>
</BaseLayout>

<script define:vars={{ tiersData, config, presets }}>
  const eur = new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });
  const SOCIAL = 0.172;

  const form = document.getElementById('sim-form');
  const get = (id) => document.getElementById(id);
  const num = (id) => Math.max(0, Number(get(id).value) || 0);

  function compute() {
    const price = num('price');
    const segment = form.querySelector('input[name="segment"]:checked').value;
    const tierKey = get('tier').value;
    const rent = num('rent');
    const charges = num('charges');
    const interests = num('interests');
    const mensualite = num('mensualite');
    const tmi = Number(get('tmi').value) || 0;
    const rate = tmi + SOCIAL;

    const tier = tiersData.find((t) => t.key === tierKey);
    if (!tier) return;
    const aRate = segment === 'neuf' ? tier.rateNeuf : tier.rateAncien;

    const loyers = rent * 12;
    const base = price * config.share;
    const amortRaw = base * aRate;
    const amort = Math.min(amortRaw, tier.cap); // plafonné par an

    // Sans dispositif
    const netSans = loyers - charges - interests;
    const taxableSans = Math.max(0, netSans);
    const taxSans = taxableSans * rate;

    // Avec dispositif : l'amortissement s'impute sur le foncier (plancher 0, excédent reporté)
    const amortUsed = Math.min(amort, taxableSans);
    const netAvec = taxableSans - amortUsed;
    const taxAvec = Math.max(0, netAvec) * rate;
    const carried = amort - amortUsed;

    const saveYear = taxSans - taxAvec;
    const save9 = saveYear * config.years;

    // Effort d'épargne mensuel (si mensualité renseignée)
    const effortMonth = mensualite + charges / 12 - rent - saveYear / 12;

    // Cartes
    get('r-annual').textContent = eur.format(amort);
    get('r-rate').textContent = `${(aRate * 100).toLocaleString('fr-FR', { minimumFractionDigits: 1, maximumFractionDigits: 1 })} % · base ${eur.format(base)}`;
    get('r-save').textContent = eur.format(saveYear);
    get('r-save9').textContent = eur.format(save9);
    get('r-effort').textContent = mensualite > 0 ? eur.format(Math.max(0, effortMonth)) : '—';
    get('r-effort-foot').textContent = mensualite > 0
      ? (effortMonth <= 0 ? 'autofinancé' : 'à financer chaque mois')
      : 'renseignez la mensualité';

    // Détail
    get('d-rent-1').textContent = eur.format(loyers);
    get('d-rent-2').textContent = eur.format(loyers);
    get('d-charges-1').textContent = '− ' + eur.format(charges);
    get('d-charges-2').textContent = '− ' + eur.format(charges);
    get('d-int-1').textContent = '− ' + eur.format(interests);
    get('d-int-2').textContent = '− ' + eur.format(interests);
    get('d-amort-1').textContent = '—';
    get('d-amort-2').textContent = '− ' + eur.format(amortUsed);
    get('d-base-1').textContent = eur.format(taxableSans);
    get('d-base-2').textContent = eur.format(Math.max(0, netAvec));
    get('d-tax-1').textContent = eur.format(taxSans);
    get('d-tax-2').textContent = eur.format(taxAvec);

    // Narratif concret
    let narrative = `Avec ce projet, vous percevez ${eur.format(loyers)} de loyers par an. `;
    if (taxableSans <= 0) {
      narrative += `Vos charges et intérêts absorbent déjà vos loyers : sans dispositif, votre revenu foncier imposable est nul. L'amortissement de ${eur.format(amort)} est alors intégralement reporté sur les années suivantes.`;
    } else {
      narrative += `Sans dispositif, votre revenu foncier imposable est de ${eur.format(taxableSans)}, soit ${eur.format(taxSans)} d'impôt et prélèvements. Avec le dispositif Jeanbrun, vous déduisez ${eur.format(amortUsed)} d'amortissement : votre base tombe à ${eur.format(Math.max(0, netAvec))}, et votre impôt à ${eur.format(taxAvec)}. Soit une économie de ${eur.format(saveYear)} par an, environ ${eur.format(save9)} sur les 9 ans d'engagement.`;
    }
    if (carried > 0) {
      narrative += ` ${eur.format(carried)} d'amortissement non utilisé cette année sont reportés.`;
    }
    get('narrative').textContent = narrative;

    drawChart(taxSans, taxAvec);

    const noteParts = [];
    noteParts.push(`Économie annuelle : ${eur.format(saveYear)}.`);
    if (carried > 0) noteParts.push(`Amortissement reporté : ${eur.format(carried)}/an.`);
    get('chart-note').textContent = noteParts.join(' ');
  }

  // Graphique en barres (SVG) : impôt sans vs avec
  function drawChart(taxSans, taxAvec) {
    // Marge en haut (padT) pour ne pas tronquer l'étiquette de valeur, et 10 %
    // de hauteur en réserve pour que la plus grande barre ne touche pas le bord.
    const max = Math.max(taxSans, taxAvec, 1) * 1.1;
    const w = 520, h = 220, padL = 16, padB = 38, padT = 34, barW = 150, gap = 90;
    const usableH = h - padB - padT;
    const x1 = padL + 60, x2 = x1 + barW + gap;
    const bar = (x, val, color, label) => {
      const bh = Math.max(2, (val / max) * usableH);
      const y = padT + usableH - bh;
      return `
        <rect x="${x}" y="${y}" width="${barW}" height="${bh}" rx="6" fill="${color}" />
        <text x="${x + barW / 2}" y="${y - 9}" text-anchor="middle" class="bar-val">${eur.format(val)}</text>
        <text x="${x + barW / 2}" y="${h - 12}" text-anchor="middle" class="bar-lbl">${label}</text>`;
    };
    const svg = `
      <svg viewBox="0 0 ${w} ${h}" width="100%" role="img" aria-label="Comparaison de l'impôt foncier annuel avec et sans le dispositif">
        <line x1="${padL}" y1="${padT + usableH}" x2="${w - padL}" y2="${padT + usableH}" stroke="var(--border)" />
        ${bar(x1, taxSans, 'var(--text-muted)', 'Sans dispositif')}
        ${bar(x2, taxAvec, 'var(--accent)', 'Avec Jeanbrun')}
      </svg>`;
    get('chart').innerHTML = svg;
  }

  function applyPreset(p) {
    get('price').value = p.values.price;
    form.querySelector(`input[name="segment"][value="${p.values.segment}"]`).checked = true;
    get('tier').value = p.values.tier;
    get('rent').value = p.values.rent;
    get('charges').value = p.values.charges;
    get('interests').value = p.values.interests;
    get('tmi').value = p.values.tmi;
    compute();
  }

  document.querySelectorAll('[data-preset]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const p = presets.find((x) => x.id === btn.getAttribute('data-preset'));
      if (p) applyPreset(p);
      document.querySelectorAll('[data-preset]').forEach((b) => b.classList.remove('is-active'));
      btn.classList.add('is-active');
    });
  });

  form.addEventListener('input', compute);
  compute();
</script>

<style>
  .presets {
    margin-top: var(--space-8);
  }
  .presets-label {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .presets-row {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-3);
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .presets-row {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .preset {
    text-align: left;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-4);
    cursor: pointer;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .preset:hover {
    border-color: var(--primary);
  }
  .preset.is-active {
    border-color: var(--primary);
    box-shadow: 0 0 0 2px rgba(27, 77, 140, 0.15);
  }
  .preset-label {
    display: block;
    font-weight: 700;
    font-size: 0.92rem;
  }
  .preset-sub {
    display: block;
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  .sim {
    display: grid;
    gap: var(--space-6);
    margin-top: var(--space-4);
  }
  @media (min-width: 640px) {
    .sim {
      grid-template-columns: 1fr 1fr;
    }
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  label,
  .field-label {
    font-weight: 600;
    font-size: 0.95rem;
  }
  input[type='number'],
  select {
    font: inherit;
    padding: var(--space-3);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--text);
    width: 100%;
  }
  .radio-row {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .radio {
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }
  .hint {
    margin: 0;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .results {
    margin-top: var(--space-8);
    display: grid;
    gap: var(--space-6);
  }
  .result-cards {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  }
  .result-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--space-4) var(--space-6);
    box-shadow: var(--shadow-sm);
  }
  .result-card.accent {
    background: var(--accent-soft);
    border-color: rgba(15, 157, 119, 0.3);
  }
  .result-label {
    margin: 0 0 var(--space-1);
    font-size: 0.82rem;
    color: var(--text-muted);
  }
  .result-value {
    margin: 0;
    font-size: 1.6rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    line-height: 1.1;
  }
  .result-card.accent .result-value {
    color: var(--accent);
  }
  .result-foot {
    margin: var(--space-1) 0 0;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .chart-title,
  .detail-title {
    margin: 0 0 var(--space-4);
    font-size: 1.15rem;
  }
  .chart-area :global(svg) {
    display: block;
    max-width: 560px;
    margin-inline: auto;
  }
  .chart-area :global(.bar-val) {
    fill: var(--text);
    font-weight: 800;
    font-size: 15px;
  }
  .chart-area :global(.bar-lbl) {
    fill: var(--text-muted);
    font-size: 13px;
  }
  .chart-note {
    margin: var(--space-4) 0 0;
    font-size: 0.9rem;
    color: var(--text-muted);
    text-align: center;
  }
  .detail .row-strong td {
    font-weight: 700;
    border-top: 2px solid var(--border);
  }
  .detail td:not(:first-child) {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .detail-narrative {
    margin: var(--space-6) 0 0;
    padding: var(--space-5) var(--space-6);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 1.02rem;
    font-family: var(--font-display);
    line-height: 1.55;
  }
</style>
