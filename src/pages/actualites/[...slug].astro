---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Cover from '../../components/Cover.astro';
import { breadcrumbSchema, newsArticleSchema, faqSchema } from '../../lib/schema';
import { photo } from '../../lib/photos';
import { SITE, EDITORIAL } from '../../consts';
import { url } from '../../lib/url';

export async function getStaticPaths() {
  const posts = await getCollection('actualites', (p) => !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFmt = (d: Date) => new Intl.DateTimeFormat('fr-FR', { dateStyle: 'long' }).format(d);
const byline = post.data.author ?? SITE.author;
// Mention partenaire : affichée uniquement si l'interrupteur est activé (off par défaut).
const showPartnerNotice = EDITORIAL.disclosePartner && post.data.partner;

// Données YMYL : fraîcheur (« à jour au »), FAQ structurée, sources officielles.
const updatedDate = post.data.updatedAt ?? post.data.publishedAt;
const faq = post.data.faq ?? [];
const sources = post.data.sources ?? [];

const crumbs = [
  { name: 'Accueil', path: '/' },
  { name: 'Actualités', path: '/actualites' },
  { name: post.data.title, path: `/actualites/${post.id}` },
];

const jsonLd = [
  breadcrumbSchema(crumbs),
  newsArticleSchema({
    title: post.data.title,
    description: post.data.description,
    slug: post.id,
    publishedAt: post.data.publishedAt,
    updatedAt: post.data.updatedAt,
  }),
  ...(faq.length ? [faqSchema(faq)] : []),
];
---

<BaseLayout
  title={post.data.title}
  metaTitle={post.data.metaTitle}
  description={post.data.description}
  path={`/actualites/${post.id}`}
  ogType="article"
  publishedTime={post.data.publishedAt.toISOString()}
  modifiedTime={updatedDate.toISOString()}
  jsonLd={jsonLd}
>
  <article class="container container-narrow article">
    <Breadcrumbs items={crumbs} />
    <Cover src={photo(`post:${post.id}`)?.src ?? post.data.cover} alt={photo(`post:${post.id}`)?.alt ?? post.data.coverAlt ?? post.data.title} credit={photo(`post:${post.id}`)?.credit ?? post.data.coverCredit} seed={post.id} variant="banner" icon="doc" loading="eager" class="article-cover" />
    <header>
      <h1>{post.data.title}</h1>
      <p class="meta">
        Par {byline} · {dateFmt(post.data.publishedAt)}
        {post.data.updatedAt && ` · Mis à jour le ${dateFmt(post.data.updatedAt)}`}
        {` · ${post.data.readingMinutes} min de lecture`}
      </p>
      <p class="freshness">À jour au {dateFmt(updatedDate)}</p>
    </header>

    {showPartnerNotice && <p class="partner-notice">Contenu réalisé en partenariat.</p>}

    <div class="prose">
      <Content />
    </div>

    {
      faq.length > 0 && (
        <section class="faq" aria-labelledby="faq-title">
          <h2 id="faq-title">Questions fréquentes</h2>
          {faq.map((item) => (
            <details>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </section>
      )
    }

    {
      sources.length > 0 && (
        <section class="sources" aria-labelledby="sources-title">
          <h2 id="sources-title">Sources</h2>
          <ul>
            {sources.map((s) => (
              <li>
                <a href={s.url} rel="nofollow noopener" target="_blank">{s.label}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <p class="disclaimer">
      Cet article a une vocation informative et ne constitue pas un conseil
      juridique ou fiscal personnalisé.
    </p>

    <p style="margin-top: var(--space-12)">
      <a class="btn btn-ghost" href={url('/actualites')}>← Toutes les actualités</a>
    </p>
  </article>
</BaseLayout>

<style>
  .article-cover {
    margin: var(--space-6) 0 0;
  }
  .article header {
    margin-top: var(--space-6);
  }
  .meta {
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .freshness {
    display: inline-block;
    margin-top: var(--space-2);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.15rem 0.7rem;
  }
  .faq {
    margin-top: var(--space-12);
  }
  .faq details {
    border-top: 1px solid var(--border);
    padding: var(--space-4) 0;
  }
  .faq summary {
    cursor: pointer;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
  }
  .faq details p {
    margin: var(--space-3) 0 0;
    color: var(--text-muted);
  }
  .sources {
    margin-top: var(--space-12);
  }
  .sources ul {
    margin: 0;
    padding-left: 1.2rem;
  }
  .sources li {
    margin: var(--space-2) 0;
    font-size: 0.95rem;
  }
  .disclaimer {
    margin-top: var(--space-10);
    padding: var(--space-4);
    border-left: 3px solid var(--border);
    background: var(--bg-soft);
    font-size: 0.85rem;
    font-style: italic;
    color: var(--text-muted);
  }
  .partner-notice {
    display: inline-block;
    font-size: 0.8rem;
    color: var(--text-muted);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.15rem 0.7rem;
  }
  .prose :global(h2) {
    margin-top: var(--space-12);
  }
  /* Aparté éditorial : serif, sans encadré ni barre latérale ; filet court en tête. */
  .prose :global(blockquote) {
    margin: var(--space-8) 0;
    padding-top: var(--space-4);
    border-top: 2px solid var(--accent);
    font-family: var(--font-display);
    font-size: 1.3rem;
    line-height: 1.45;
    color: var(--text);
  }
  .prose :global(blockquote p) {
    margin: 0;
  }
</style>
