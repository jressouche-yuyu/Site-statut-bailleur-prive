---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Cover from '../../components/Cover.astro';
import { breadcrumbSchema, itemListSchema } from '../../lib/schema';
import { url } from '../../lib/url';

const crumbs = [
  { name: 'Accueil', path: '/' },
  { name: 'Actualités', path: '/actualites' },
];

const posts = (await getCollection('actualites', (p) => !p.data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const jsonLd = [
  breadcrumbSchema(crumbs),
  itemListSchema(
    posts.map((p) => ({ name: p.data.title, path: `/actualites/${p.id}` })),
    'Actualités du statut du bailleur privé',
  ),
];

const dateFmt = (d: Date) => new Intl.DateTimeFormat('fr-FR', { dateStyle: 'long' }).format(d);
---

<BaseLayout
  title="Actualités du statut du bailleur privé (dispositif Jeanbrun)"
  description="Suivez l'actualité du dispositif Jeanbrun : adoption au budget 2026, décrets d'application, évolutions des taux et conditions du statut du bailleur privé."
  path="/actualites"
  jsonLd={jsonLd}
>
  <div class="container container-narrow">
    <Breadcrumbs items={crumbs} />
    <p class="eyebrow">Actualités & analyses</p>
    <h1>Le blog du statut du bailleur privé</h1>
    <p class="lead">
      Actualités, décryptages, analyses et contributions autour du dispositif
      Jeanbrun et de l'investissement locatif. Nous suivons le sujet de près et
      mettons nos contenus à jour au fil des textes.
    </p>

    <div class="post-list">
      {
        posts.map((post) => (
          <a class="post" href={url(`/actualites/${post.id}`)}>
            <Cover src={post.data.cover} alt={post.data.coverAlt ?? post.data.title} credit={post.data.coverCredit} seed={post.id} variant="thumb" icon="doc" class="post-cover" />
            <div class="post-body">
              <time datetime={post.data.publishedAt.toISOString()}>{dateFmt(post.data.publishedAt)}</time>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <span class="post-cta">Lire →</span>
            </div>
          </a>
        ))
      }
    </div>

    <p class="rss-link">
      <a href={url('/rss.xml')}>Flux RSS des actualités et guides</a>
    </p>
  </div>
</BaseLayout>

<style>
  .post-list {
    display: grid;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }
  .post {
    display: grid;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    color: var(--text);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.15s ease, border-color 0.15s ease;
  }
  @media (min-width: 640px) {
    .post {
      grid-template-columns: 240px 1fr;
      align-items: stretch;
    }
  }
  .post :global(.post-cover) {
    border-radius: 0;
    height: 100%;
  }
  @media (max-width: 639px) {
    .post :global(.post-cover) {
      border-radius: var(--radius) var(--radius) 0 0;
    }
  }
  .post-body {
    padding: var(--space-6);
  }
  .post:hover {
    text-decoration: none;
    border-color: var(--primary);
    box-shadow: var(--shadow);
  }
  .post time {
    color: var(--text-muted);
    font-size: 0.85rem;
  }
  .post h2 {
    margin: var(--space-2) 0;
    font-size: 1.3rem;
  }
  .post p {
    color: var(--text-muted);
    margin: 0 0 var(--space-2);
  }
  .post-cta {
    color: var(--primary);
    font-weight: 600;
  }
  .rss-link {
    margin-top: var(--space-8);
    font-size: 0.9rem;
  }
</style>
