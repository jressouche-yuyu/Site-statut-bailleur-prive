---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Faq from '../components/Faq.astro';
import RateTable from '../components/RateTable.astro';
import BaremeChart from '../components/BaremeChart.astro';
import Steps from '../components/Steps.astro';
import Compare from '../components/Compare.astro';
import Cover from '../components/Cover.astro';
import { guides, categoryIcon } from '../data/guides';
import { photo } from '../lib/photos';
import { logo as brandLogo } from '../lib/logos';
import { faq } from '../data/faq';
import { dispositif, formatEur } from '../data/dispositif';
import { breadcrumbSchema, dispositifSchema, faqSchema } from '../lib/schema';
import { url } from '../lib/url';

const homeFaq = faq.slice(0, 6);

// Flux unifié : guides + actualités fusionnés et triés du plus récent au plus
// ancien. La home reflète ainsi automatiquement le dernier contenu publié.
interface FeedItem {
  kind: 'guide' | 'actu';
  type: string;
  title: string;
  description: string;
  date: Date;
  href: string;
  seed: string;
  src?: string;
  alt: string;
  icon: 'building' | 'key' | 'chart' | 'doc';
}

const guideItems: FeedItem[] = guides.map((g) => {
  const p = photo(`guide:${g.slug}`);
  return {
    kind: 'guide', type: g.category, title: g.title, description: g.description,
    date: new Date(g.publishedAt), href: `/guides/${g.slug}`, seed: g.slug,
    src: p?.src ?? g.cover, alt: p?.alt ?? g.coverAlt ?? g.title, icon: categoryIcon[g.category],
  };
});
const actuItems: FeedItem[] = (await getCollection('actualites', (p) => !p.data.draft)).map((p) => {
  const ph = photo(`post:${p.id}`);
  return {
    kind: 'actu', type: 'Actualité', title: p.data.title, description: p.data.description,
    date: p.data.publishedAt, href: `/actualites/${p.id}`, seed: p.id,
    src: ph?.src ?? p.data.cover, alt: ph?.alt ?? p.data.coverAlt ?? p.data.title, icon: 'doc',
  };
});
const feed = [...guideItems, ...actuItems].sort((a, b) => b.date.getTime() - a.date.getTime());
const featured = feed[0];
const recent = feed.slice(1, 7);
const fmtDate = (d: Date) => d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });

// Écosystème : grands acteurs (wordmarks, remplaçables par de vrais logos) et
// principales métropoles concernées.
// `brand` = couleur d'accent (proche de la charte de la marque), révélée au
// survol — purement éditorial, comme la mise en couleur des futurs vrais logos.
const acteurs = [
  { name: 'Nexity', slug: 'nexity', brand: '#E2001A' },
  { name: 'Bouygues Immobilier', slug: 'bouygues-immobilier', brand: '#0093D0' },
  { name: 'Cogedim', slug: 'cogedim', brand: '#1A2A4F' },
  { name: 'Vinci Immobilier', slug: 'vinci-immobilier', brand: '#C8102E' },
  { name: 'Icade', slug: 'icade', brand: '#E6007E' },
  { name: 'Kaufman & Broad', slug: 'kaufman-broad', brand: '#D71920' },
  { name: 'Pichet', slug: 'pichet', brand: '#E30613' },
  { name: 'Nacarat', slug: 'nacarat', brand: '#F25C3B' },
];
const territoires = [
  { ville: 'Grand Paris', dpt: '75 · 92 · 93 · 94' },
  { ville: 'Lyon', dpt: '69' },
  { ville: 'Toulouse', dpt: '31' },
  { ville: 'Bordeaux', dpt: '33' },
  { ville: 'Nantes', dpt: '44' },
  { ville: 'Lille', dpt: '59' },
  { ville: 'Montpellier', dpt: '34' },
  { ville: 'Rennes', dpt: '35' },
  { ville: 'Marseille', dpt: '13' },
  { ville: 'Nice', dpt: '06' },
];
const heroPhoto = photo('home:hero');

const jsonLd = [
  breadcrumbSchema([{ name: 'Accueil', path: '/' }]),
  dispositifSchema(homeFaq),
  faqSchema(homeFaq),
];
---

<BaseLayout
  title="Statut du bailleur privé (dispositif Jeanbrun) : guide complet 2026"
  description="Tout sur le statut du bailleur privé, alias dispositif Jeanbrun : fonctionnement de l'amortissement, taux, conditions d'éligibilité, simulateur et actualités. Guide indépendant 2026."
  path="/"
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="eyebrow">Loi de finances 2026 · Mis à jour en {new Date(dispositif.lastReviewed).getFullYear()}</p>
        <h1>Le statut du bailleur privé, expliqué clairement</h1>
        <p class="lead">
          Aussi appelé <strong>dispositif Jeanbrun</strong>, le statut du bailleur
          privé permet d'<strong>amortir</strong> une partie du prix d'un logement
          loué nu. Fonctionnement, taux, conditions et simulateur : tout est ici.
        </p>
        <div class="hero-actions">
          <a class="btn" href={url('/dispositif-jeanbrun')}>Comprendre le dispositif</a>
          <a class="btn btn-ghost" href={url('/simulateur')}>Simuler mon amortissement</a>
        </div>
        <ul class="trust">
          {[
            'Sources officielles (PLF 2026)',
            `Mis à jour en ${new Date(dispositif.lastReviewed).toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' })}`,
            'Indépendant, sans conseil intéressé',
          ].map((t) => (
            <li>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              <span>{t}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="hero-art" aria-hidden={heroPhoto ? undefined : 'true'}>
        {heroPhoto ? (
          <figure class="hero-photo">
            <img src={url(heroPhoto.src)} alt={heroPhoto.alt ?? 'Immeuble résidentiel'} width="720" height="560" fetchpriority="high" />
          </figure>
        ) : (
        <svg viewBox="0 0 360 300" width="100%" role="img" aria-label="Illustration : immeuble et courbe d'amortissement fiscal">
          <defs>
            <linearGradient id="hb" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#1d2a3f" />
              <stop offset="1" stop-color="#3a4a63" />
            </linearGradient>
          </defs>
          <rect x="20" y="40" width="220" height="236" rx="14" fill="var(--bg-soft)" stroke="var(--border)" />
          {/* immeuble */}
          <rect x="56" y="78" width="92" height="170" rx="6" fill="url(#hb)" />
          <rect x="160" y="120" width="58" height="128" rx="6" fill="var(--primary)" opacity="0.85" />
          {[78,110,142,174,206].map((fy) => (
            <g>
              <rect x={70} y={fy} width="18" height="16" rx="2" fill="#fff" opacity="0.9" />
              <rect x={100} y={fy} width="18" height="16" rx="2" fill="#fff" opacity="0.9" />
            </g>
          ))}
          {[140,172,204].map((fy) => (
            <rect x={172} y={fy} width="16" height="14" rx="2" fill="#fff" opacity="0.85" />
          ))}
          {/* carte "amortissement" + courbe */}
          <rect x="170" y="26" width="172" height="120" rx="12" fill="var(--surface)" stroke="var(--border)" />
          <text x="186" y="50" class="art-cap">Amortissement</text>
          <polyline points="186,128 214,112 244,108 274,86 304,74 326,58" fill="none" stroke="var(--accent)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
          {[[186,128],[214,112],[244,108],[274,86],[304,74],[326,58]].map((p) => (
            <circle cx={p[0]} cy={p[1]} r="3.5" fill="var(--accent)" />
          ))}
          <text x="186" y="76" class="art-pct">−5,5%/an</text>
        </svg>
        )}
      </div>
    </div>
  </section>

  <section class="section container">
    <div class="grid grid-3 stats">
      <div class="card stat-card">
        <span class="stat-ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V8l7-5 7 5v13M9 21v-6h6v6"/></svg>
        </span>
        <p class="stat">80 %</p>
        <p>du prix du logement amortissable (hors quote-part terrain).</p>
      </div>
      <div class="card stat-card">
        <span class="stat-ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M19 5 5 19M6.5 9a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM17.5 20a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"/></svg>
        </span>
        <p class="stat">jusqu'à 5,5 %</p>
        <p>d'amortissement par an dans le neuf, selon l'effort de loyer.</p>
      </div>
      <div class="card stat-card">
        <span class="stat-ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9h18M7 3v3m10-3v3M5 5h14a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z"/></svg>
        </span>
        <p class="stat">9 ans</p>
        <p>d'engagement de location nue en résidence principale.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <Steps
        title="Comment ça marche, en 4 étapes"
        steps={[
          { icon: 'building', title: 'Acheter un appartement', body: 'Un logement collectif acquis dans la fenêtre d\'éligibilité, destiné à la location nue.' },
          { icon: 'percent', title: 'Choisir son loyer', body: 'Intermédiaire, social ou très social : plus le loyer est bas, plus le taux d\'amortissement est élevé.' },
          { icon: 'calendar', title: 'Louer 9 ans', body: 'S\'engager à louer en résidence principale au loyer plafonné pendant au moins 9 ans.' },
          { icon: 'piggy', title: 'Amortir & déduire', body: 'Déduire chaque année l\'amortissement (80 % du prix × taux) de ses revenus fonciers.' },
        ]}
      />
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <h2 style="margin-top:0">Les taux d'amortissement en un coup d'œil</h2>
      <p class="lead" style="margin-bottom:var(--space-6)">
        Plus le loyer consenti est bas, plus le taux d'amortissement est élevé.
        L'amortissement porte sur 80 % du prix d'acquisition.
      </p>
      <BaremeChart />
      <RateTable />
      <p class="table-note">
        Plafonds de déduction : {formatEur(8000)} (intermédiaire), {formatEur(10000)} (social),
        {formatEur(12000)} (très social). <a href={url('/dispositif-jeanbrun')}>Voir le détail des conditions →</a>
      </p>
    </div>
  </section>

  <section class="section container">
    <div class="section-head">
      <h2>Derniers contenus</h2>
      <span class="see-all-group">
        <a class="see-all" href={url('/guides')}>Guides</a>
        <a class="see-all" href={url('/actualites')}>Actualités</a>
      </span>
    </div>

    {
      featured && (
        <a class="feature-card" href={url(featured.href)}>
          <Cover src={featured.src} alt={featured.alt} seed={featured.seed} variant="thumb" icon={featured.icon} loading="eager" class="feature-cover" />
          <div class="feature-body">
            <span class="badge badge-accent">{featured.kind === 'guide' ? featured.type : 'Actualité'}</span>
            <h3>{featured.title}</h3>
            <p>{featured.description}</p>
            <span class="feature-meta">{fmtDate(featured.date)}</span>
            <span class="link-card-cta">Lire →</span>
          </div>
        </a>
      )
    }

    <div class="grid grid-3 recent-grid">
      {
        recent.map((it) => (
          <a class="link-card" href={url(it.href)}>
            <Cover src={it.src} alt={it.alt} seed={it.seed} variant="thumb" icon={it.icon} />
            <div class="link-card-body">
              <span class="badge badge-accent">{it.kind === 'guide' ? it.type : 'Actualité'}</span>
              <h3>{it.title}</h3>
              <p>{it.description}</p>
              <span class="link-card-cta">{it.kind === 'guide' ? 'Lire le guide →' : "Lire l'article →"}</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section container">
    <div class="section-head">
      <h2>Les territoires concernés</h2>
      <a class="see-all" href={url('/guides/ou-investir-dispositif-jeanbrun-departements')}>Où investir ? →</a>
    </div>
    <p class="lead" style="margin-bottom:var(--space-6)">
      Le dispositif s'applique partout en France ; le potentiel se concentre dans
      les grandes métropoles à forte demande locative.
    </p>
    <ul class="territoires">
      {
        territoires.map((t) => (
          <li>
            <a href={url('/guides/ou-investir-dispositif-jeanbrun-departements')}>
              <span class="terr-ville">{t.ville}</span>
              <span class="terr-dpt">{t.dpt}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="section section-soft">
    <div class="container">
      <div class="section-head">
        <h2 style="margin-top:0">Les acteurs du marché</h2>
        <a class="see-all" href={url('/guides/acteurs-dispositif-jeanbrun-promoteurs-conseils')}>Panorama des acteurs →</a>
      </div>
      <p class="lead" style="margin-bottom:var(--space-6)">
        Promoteurs et conseils positionnés sur le statut du bailleur privé.
      </p>
      <ul class="logos">
        {
          acteurs.map((a) => {
            const l = brandLogo(a.slug);
            return (
              <li class="logo-chip" style={`--brand:${a.brand}`}>
                {l ? <img src={url(l.src)} alt={a.name} loading="lazy" /> : <span>{a.name}</span>}
              </li>
            );
          })
        }
      </ul>
      <p class="logos-note">Noms cités à titre informatif — aucun lien commercial ni partenariat impliqué.</p>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <h2 style="margin-top:0">Jeanbrun face au Pinel et au LMNP</h2>
      <p class="lead" style="margin-bottom:var(--space-4)">
        Le dispositif succède au Pinel avec une logique différente, et emprunte au
        LMNP son mécanisme d'amortissement — mais pour la location nue.
      </p>
      <Compare />
      <p>
        <a class="link-card-cta" href={url('/guides/dispositif-jeanbrun-vs-pinel-lmnp')}>
          Lire le comparatif détaillé →
        </a>
      </p>
    </div>
  </section>

  <section class="section container editorial">
    <h2>Statut du bailleur privé : de quoi parle-t-on ?</h2>
    <p>
      Le <strong>statut du bailleur privé</strong>, popularisé sous le nom de
      <strong> dispositif Jeanbrun</strong>, est une mesure de la loi de finances
      pour 2026 destinée à relancer l'investissement locatif après l'arrêt du
      Pinel fin 2024. Sa nouveauté : permettre au propriétaire d'un logement
      <strong> loué nu</strong> d'en <strong>amortir</strong> une partie, c'est-à-dire
      de déduire chaque année une fraction de sa valeur de ses revenus fonciers —
      un avantage jusqu'ici réservé à la location meublée.
    </p>
    <p>
      En contrepartie, le bailleur s'engage à louer pendant au moins neuf ans à un
      <a href={url('/glossaire#loyer-intermediaire')}>loyer plafonné</a>. Plus
      l'effort sur le loyer est important (intermédiaire, social ou très social),
      plus le taux d'amortissement est élevé. Notre
      <a href={url('/dispositif-jeanbrun')}> page de référence</a>,
      nos <a href={url('/guides')}>guides</a> et notre
      <a href={url('/simulateur')}> simulateur</a> vous aident à évaluer l'intérêt
      du dispositif pour votre projet.
    </p>
    <p class="disclaimer">
      Information éditoriale indépendante, à jour de la version adoptée fin 2025.
      Les paramètres définitifs dépendent des décrets d'application : ce contenu ne
      constitue pas un conseil fiscal personnalisé.
    </p>
  </section>

  <div class="container">
    <Faq items={homeFaq} title="Questions fréquentes sur le statut du bailleur privé" />
  </div>
</BaseLayout>

<style>
  .hero {
    background:
      radial-gradient(1100px 460px at 12% -10%, rgba(164, 116, 43, 0.1), transparent 60%),
      linear-gradient(180deg, var(--bg-soft) 0%, var(--bg) 100%);
    border-bottom: 1px solid var(--border);
    padding-block: var(--space-16);
  }
  .hero-inner {
    display: grid;
    gap: var(--space-8);
    align-items: center;
  }
  @media (min-width: 900px) {
    .hero-inner {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }
  .hero-text {
    max-width: 620px;
  }
  .hero h1 {
    font-size: clamp(2.6rem, 7vw, 4.4rem);
    line-height: 1.04;
    margin-bottom: var(--space-6);
  }
  .hero .lead {
    max-width: 52ch;
    font-size: 1.25rem;
  }
  .hero-art {
    display: none;
  }
  @media (min-width: 900px) {
    .hero-art {
      display: block;
    }
  }
  .hero-art :global(.art-cap) {
    fill: var(--text-muted);
    font-size: 13px;
    font-weight: 600;
  }
  .hero-art :global(.art-pct) {
    fill: var(--accent);
    font-size: 22px;
    font-weight: 800;
  }
  .hero-photo {
    position: relative;
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .hero-photo img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }
  .hero-photo figcaption {
    position: absolute;
    right: 6px;
    bottom: 6px;
    font-size: 0.68rem;
    color: #fff;
    background: rgba(11, 28, 51, 0.55);
    padding: 1px 7px;
    border-radius: 999px;
  }
  .hero-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-6);
  }
  .trust {
    list-style: none;
    padding: var(--space-4) 0 0;
    margin: var(--space-6) 0 0;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-6);
  }
  .trust li {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .trust li svg {
    color: var(--accent);
    flex-shrink: 0;
  }

  .stats {
    margin-top: 0;
  }
  .stat-card p:last-child {
    margin: var(--space-2) 0 0;
    color: var(--text-muted);
  }
  .stat-ico {
    display: inline-grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(27, 77, 140, 0.08);
    color: var(--primary);
    margin-bottom: var(--space-3);
  }

  .table-note {
    margin-top: var(--space-4);
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .link-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    color: var(--text);
    height: 100%;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.15s ease, transform 0.15s ease, border-color 0.15s ease;
  }
  .link-card:hover {
    border-color: var(--primary);
    text-decoration: none;
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }
  .link-card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6);
    flex: 1;
  }
  .link-card h3 {
    margin: 0;
  }
  .link-card p {
    color: var(--text-muted);
    margin: 0;
  }
  .link-card .badge {
    align-self: flex-start;
  }
  .card-date {
    color: var(--text-muted);
    font-size: 0.85rem;
  }
  .link-card-cta {
    margin-top: auto;
    color: var(--primary);
    font-weight: 600;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }
  .section-head h2 {
    margin: 0;
  }
  .see-all-group {
    display: inline-flex;
    gap: var(--space-4);
  }

  /* Carte « à la une » du flux unifié */
  .feature-card {
    display: grid;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    color: var(--text);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.15s ease, border-color 0.15s ease;
  }
  @media (min-width: 720px) {
    .feature-card {
      grid-template-columns: 1.1fr 1fr;
    }
  }
  .feature-card:hover {
    text-decoration: none;
    border-color: var(--primary);
    box-shadow: var(--shadow);
  }
  .feature-card :global(.feature-cover) {
    border-radius: 0;
    height: 100%;
    min-height: 220px;
  }
  .feature-body {
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-self: center;
  }
  .feature-body .badge {
    align-self: flex-start;
  }
  .feature-body h3 {
    margin: 0;
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
  }
  .feature-body p {
    margin: 0;
    color: var(--text-muted);
  }
  .feature-meta {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .recent-grid {
    margin-top: var(--space-6);
  }

  /* Territoires */
  .territoires {
    list-style: none;
