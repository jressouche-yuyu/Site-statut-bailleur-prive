---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Callout from '../components/Callout.astro';
import { breadcrumbSchema } from '../lib/schema';
import { SITE } from '../consts';
import { url } from '../lib/url';

const crumbs = [
  { name: 'Accueil', path: '/' },
  { name: 'Partenariats', path: '/partenariats' },
];
const jsonLd = [breadcrumbSchema(crumbs)];
---

<BaseLayout
  title="Partenariats & contenus sponsorisés"
  description={`Travaillez avec ${SITE.name} : articles partenaires, contenus sponsorisés et collaborations éditoriales autour de l'immobilier locatif et de la fiscalité.`}
  path="/partenariats"
  jsonLd={jsonLd}
>
  <div class="container container-narrow prose">
    <Breadcrumbs items={crumbs} />
    <p class="eyebrow">Partenariats</p>
    <h1>Collaborer avec {SITE.name}</h1>
    <p class="lead">
      {SITE.name} est un média de référence sur le statut du bailleur privé et
      l'investissement locatif. Nous proposons des collaborations éditoriales aux
      acteurs sérieux du secteur.
    </p>

    <h2>Notre audience</h2>
    <p>
      Nos lecteurs sont des <strong>investisseurs particuliers</strong>, des
      propriétaires bailleurs et des professionnels du patrimoine en recherche
      d'information fiable sur la fiscalité immobilière et le dispositif Jeanbrun.
      Un public qualifié, avec une forte intention.
    </p>

    <h2>Formats de collaboration</h2>
    <ul>
      <li><strong>Article partenaire</strong> : un contenu éditorial de qualité, en lien avec notre thématique, intégrant un lien vers votre site.</li>
      <li><strong>Contenu sponsorisé</strong> : mise en avant d'une offre ou d'un service pertinent pour notre audience, clairement identifié comme tel.</li>
      <li><strong>Citation d'expert / tribune</strong> : nous accueillons l'expertise de professionnels reconnus (notaires, CGP, experts-comptables, promoteurs).</li>
    </ul>

    <Callout title="Notre exigence éditoriale">
      <p>
        Nous n'acceptons que des partenariats <strong>pertinents et de qualité</strong>,
        en cohérence avec notre ligne. Les contenus sponsorisés sont signalés. Nous
        nous réservons le droit de refuser toute collaboration qui nuirait à la
        confiance de nos lecteurs ou à la qualité du site.
      </p>
    </Callout>

    <h2>Nous contacter</h2>
    <p>
      Pour discuter d'un partenariat, écrivez-nous à
      <a href={`mailto:${SITE.email}`}> {SITE.email}</a> en précisant votre
      activité, le format souhaité et l'URL concernée. Vous pouvez aussi passer par
      notre <a href={url('/contact')}>formulaire de contact</a>.
    </p>
  </div>
</BaseLayout>
